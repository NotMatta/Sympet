{% extends 'base.html.twig' %}

{% block title %}My Orders | Sympet{% endblock %}

{% block body %}
<div class="min-h-screen noto-sans flex flex-col bg-gray-50">
    {% include 'includes/navbar.html.twig' with {
        cartItemCount: cartItemCount,
        savedItemsCount: savedItemsCount,
        search: search,
        sort: sort,
        selectedCategories: selectedCategories
    } %}
    <main class="grow px-4 py-6">
        <div class="mx-auto max-w-5xl space-y-4">
            <h1 class="text-2xl font-bold text-gray-900">My Orders</h1>
            {% if orders is empty %}
                <div class="rounded-lg border border-dashed border-gray-300 bg-white p-8 text-center text-gray-600">
                    No orders yet.
                </div>
            {% else %}
                <div class="space-y-3">
                    {% for order in orders %}
                        <article class="rounded-lg border border-black/10 bg-white p-4 shadow-sm">
                            <div class="flex flex-wrap items-center justify-between gap-3">
                                <div>
                                    <p class="font-semibold text-gray-900">{{ order.orderNumber }}</p>
                                    <p class="text-sm text-gray-500">{{ order.createdAt|date('Y-m-d H:i') }}</p>
                                </div>
                                <p class="text-sm text-gray-700">Status: <span class="font-medium">{{ order.status }}</span></p>
                                <p class="font-semibold text-gray-900">{{ order.total|number_format(2, '.', ',') }} DT</p>
                                <a href="{{ path('app_order_detail', {id: order.id}) }}" class="rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-700 hover:bg-gray-100">Details</a>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </main>
</div>
{% endblock %}
