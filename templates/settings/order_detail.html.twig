{% extends 'base.html.twig' %}

{% block title %}Order {{ order.orderNumber }} | Sympet{% endblock %}

{% block body %}
<div class="min-h-screen noto-sans flex flex-col bg-gray-50">
    {% include 'includes/navbar.html.twig' with {
        cartItemCount: cartItemCount,
        savedItemsCount: savedItemsCount,
        search: search,
        sort: sort,
        selectedCategories: selectedCategories
    } %}
    <main class="grow px-4 py-6">
        <div class="mx-auto max-w-5xl space-y-4">
            <a href="{{ path('app_orders') }}" class="text-sm text-orange-600 hover:text-orange-700">← Back to orders</a>
            <div class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
                <h1 class="text-2xl font-bold text-gray-900">{{ order.orderNumber }}</h1>
                <p class="text-sm text-gray-500">Placed on {{ order.createdAt|date('Y-m-d H:i') }}</p>
                <p class="mt-1 text-sm text-gray-600">Status: {{ order.status }}</p>
            </div>
            <div class="rounded-lg border border-black/10 bg-white p-5 shadow-sm">
                <h2 class="text-lg font-semibold text-gray-900 mb-3">Items</h2>
                <div class="space-y-2">
                    {% for item in order.items %}
                        <div class="flex items-center justify-between border-b border-gray-100 pb-2">
                            <div>
                                <p class="font-medium text-gray-900">{{ item.productName }}</p>
                                <p class="text-sm text-gray-500">{{ item.quantity }} × {{ item.unitPrice|number_format(2, '.', ',') }} DT</p>
                            </div>
                            <p class="font-semibold text-gray-900">{{ (item.quantity * item.unitPrice)|number_format(2, '.', ',') }} DT</p>
                        </div>
                    {% endfor %}
                </div>
                <div class="mt-4 border-t border-gray-200 pt-3 flex items-center justify-between">
                    <span class="font-semibold text-gray-900">Total</span>
                    <span class="font-semibold text-gray-900">{{ order.total|number_format(2, '.', ',') }} DT</span>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}
