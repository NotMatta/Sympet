{% extends 'base.html.twig' %}

{% block title %}Reset Password | Sympet{% endblock %}

{% block body %}
<div class="min-h-screen noto-sans flex flex-col bg-gray-50">
    {% include 'includes/navbar.html.twig' with {
        cartItemCount: cartItemCount,
        savedItemsCount: savedItemsCount,
        search: search,
        sort: sort,
        selectedCategories: selectedCategories
    } %}
    <main class="grow px-4 py-10">
        <div class="mx-auto max-w-md rounded-lg border border-black/10 bg-white p-6 shadow-sm">
            <h1 class="text-2xl font-bold text-gray-900 mb-4">Reset password</h1>
            {{ form_start(resetForm, {attr: {class: 'space-y-4'}}) }}
                <div>
                    {{ form_label(resetForm.plainPassword.first, null, {label_attr: {class: 'text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(resetForm.plainPassword.first, {attr: {class: 'mt-1 w-full rounded-md border border-gray-300 px-3 py-2 text-sm'}}) }}
                    {{ form_errors(resetForm.plainPassword.first) }}
                </div>
                <div>
                    {{ form_label(resetForm.plainPassword.second, null, {label_attr: {class: 'text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(resetForm.plainPassword.second, {attr: {class: 'mt-1 w-full rounded-md border border-gray-300 px-3 py-2 text-sm'}}) }}
                    {{ form_errors(resetForm.plainPassword.second) }}
                </div>
                <button type="submit" class="w-full rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600">Update password</button>
            {{ form_end(resetForm) }}
        </div>
    </main>
</div>
{% endblock %}
