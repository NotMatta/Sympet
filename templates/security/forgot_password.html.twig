{% extends 'base.html.twig' %}

{% block title %}Forgot Password | Sympet{% endblock %}

{% block body %}
<div class="min-h-screen noto-sans flex flex-col bg-gray-50">
    {% include 'includes/navbar.html.twig' with {
        cartItemCount: cartItemCount,
        savedItemsCount: savedItemsCount,
        search: search,
        sort: sort,
        selectedCategories: selectedCategories
    } %}
    <main class="grow px-4 py-10">
        <div class="mx-auto max-w-md rounded-lg border border-black/10 bg-white p-6 shadow-sm">
            <h1 class="text-2xl font-bold text-gray-900 mb-2">Forgot password</h1>
            <p class="text-sm text-gray-600 mb-4">Enter your email and we will send a reset link.</p>
            {{ form_start(requestForm, {attr: {class: 'space-y-4'}}) }}
                <div>
                    {{ form_label(requestForm.email, null, {label_attr: {class: 'text-sm font-medium text-gray-700'}}) }}
                    {{ form_widget(requestForm.email, {attr: {class: 'mt-1 w-full rounded-md border border-gray-300 px-3 py-2 text-sm'}}) }}
                    {{ form_errors(requestForm.email) }}
                </div>
                <button type="submit" class="w-full rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600">Send reset link</button>
            {{ form_end(requestForm) }}
        </div>
    </main>
</div>
{% endblock %}
