{% extends 'base.html.twig' %}

{% block title %}Login | Sympet{% endblock %}

{% block body %}
<div class="min-h-screen noto-sans flex flex-col bg-gray-50">
    {% include 'includes/navbar.html.twig' with {
        cartItemCount: cartItemCount,
        savedItemsCount: savedItemsCount,
        search: search,
        sort: sort,
        selectedCategories: selectedCategories
    } %}
    <main class="grow px-4 py-10">
        <div class="mx-auto max-w-md rounded-lg border border-black/10 bg-white p-6 shadow-sm">
            <h1 class="text-2xl font-bold text-gray-900 mb-4">Sign in</h1>
            {% if error %}
                <div class="mb-4 rounded-md bg-red-50 px-3 py-2 text-sm text-red-700">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mb-3 rounded-md px-3 py-2 text-sm {% if type == 'success' %}bg-emerald-50 text-emerald-700{% elseif type == 'error' %}bg-red-50 text-red-700{% else %}bg-amber-50 text-amber-700{% endif %}">{{ message }}</div>
                {% endfor %}
            {% endfor %}
            <form method="post" class="space-y-4">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <div>
                    <label class="text-sm font-medium text-gray-700">Email</label>
                    <input type="email" name="email" value="{{ last_username }}" required class="mt-1 w-full rounded-md border border-gray-300 px-3 py-2 text-sm">
                </div>
                <div>
                    <label class="text-sm font-medium text-gray-700">Password</label>
                    <input type="password" name="password" required class="mt-1 w-full rounded-md border border-gray-300 px-3 py-2 text-sm">
                </div>
                <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                    <input type="checkbox" name="_remember_me" class="rounded border-gray-300">
                    Remember me
                </label>
                <button type="submit" class="w-full rounded-md bg-orange-500 px-4 py-2 text-sm font-semibold text-white hover:bg-orange-600">Login</button>
            </form>
            <div class="mt-4 space-y-2 text-sm">
                <a href="{{ path('app_forgot_password') }}" class="text-orange-600 hover:text-orange-700">Forgot password?</a>
                <p class="text-gray-600">No account? <a href="{{ path('app_register') }}" class="text-orange-600">Register</a></p>
            </div>
            <div class="mt-6 grid gap-2">
                <a href="{{ path('app_oauth_google') }}" class="rounded-md border border-gray-300 px-4 py-2 text-center text-sm font-medium text-gray-700 hover:bg-gray-100">Login with Google</a>
                <a href="{{ path('app_oauth_github') }}" class="rounded-md border border-gray-300 px-4 py-2 text-center text-sm font-medium text-gray-700 hover:bg-gray-100">Login with GitHub</a>
            </div>
        </div>
    </main>
</div>
{% endblock %}
