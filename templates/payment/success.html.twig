{% extends 'base.html.twig' %}

{% block title %}Payment Successful | Sympet{% endblock %}

{% block body %}
<div class="min-h-screen noto-sans flex flex-col bg-gray-50">
    {% include 'includes/navbar.html.twig' with {
        search: search,
        selectedCategories: selectedCategories,
        sort: sort,
        cartItemCount: cartItemCount,
        savedItemsCount: savedItemsCount
    } %}

    <main class="w-full grow px-4 py-10">
        <div class="mx-auto w-full max-w-2xl rounded-lg border border-black/10 bg-white p-8 text-center shadow-sm">
            <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-emerald-100 text-emerald-600">
                {{ ux_icon('mdi:check', {class: 'w-8 h-8'}) }}
            </div>
            <h1 class="text-2xl font-bold text-gray-900">Thank you for your order!</h1>
            <p class="mt-2 text-sm text-gray-600">Your payment was completed successfully.</p>

            {% if checkoutSession %}
                <p class="mt-4 text-xs text-gray-500">Payment reference: {{ checkoutSession.id }}</p>
                {% if checkoutSession.amount_total is defined %}
                    <p class="text-sm font-medium text-gray-800">Paid: {{ (checkoutSession.amount_total / 100)|number_format(2, '.', ',') }} {{ checkoutSession.currency|upper }}</p>
                {% endif %}
            {% endif %}

            <a href="{{ path('app_shop') }}" class="mt-6 inline-flex rounded-md bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">
                Continue shopping
            </a>
        </div>
    </main>
</div>
{% endblock %}
