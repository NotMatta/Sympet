<nav class="w-full flex flex-col px-4 bg-white sticky top-0">
    <div class="w-full flex justify-between items-center h-16">
        <div class="w-1/3 h-full flex items-center">
            <h1 class="font-bold lobster-regular text-3xl">Sympet</h1>
        </div>
        <div class="w-1/3 h-full flex items-center justify-center">
            <form action="{{ path('app_shop') }}" method="get" class="flex items-center gap-2 rounded-md px-3 py-1 w-full max-w-md bg-black/10 h-10">
                {{ ux_icon('mdi:magnify', {class: "w-5 h-5"}) }}
                <input
                    name="search"
                    value="{{ search ?? '' }}"
                    placeholder="Search products"
                    class="focus:outline-none grow bg-transparent"
                >
                {% if sort is defined and sort %}
                    <input type="hidden" name="sort" value="{{ sort }}">
                {% endif %}
                {% if selectedCategories is defined %}
                    {% for categoryId in selectedCategories %}
                        <input type="hidden" name="categories[]" value="{{ categoryId }}">
                    {% endfor %}
                {% endif %}
            </form>
        </div>
        <div class="flex items-center justify-end gap-6 w-1/3 h-full">
            <a href="{{ path('app_saved_index') }}" class="relative inline-flex items-center justify-center text-gray-800 hover:text-orange-600 transition-colors">
                {{ ux_icon('mdi:heart-outline', {class: "w-6 h-6"}) }}
                <span
                    data-saved-count
                    class="absolute -right-2 -top-2 inline-flex min-w-5 h-5 items-center justify-center rounded-full bg-orange-500 px-1 text-[11px] font-semibold text-white {% if (savedItemsCount|default(0)) == 0 %}hidden{% endif %}"
                >
                    {{ savedItemsCount|default(0) }}
                </span>
            </a>
            <a href="{{ path('app_cart_index') }}" class="relative inline-flex items-center justify-center text-gray-800 hover:text-orange-600 transition-colors">
                {{ ux_icon('mdi:cart-outline', {class: "w-6 h-6"}) }}
                <span
                    data-cart-count
                    class="absolute -right-2 -top-2 inline-flex min-w-5 h-5 items-center justify-center rounded-full bg-orange-500 px-1 text-[11px] font-semibold text-white {% if (cartItemCount|default(0)) == 0 %}hidden{% endif %}"
                >
                    {{ cartItemCount|default(0) }}
                </span>
            </a>
            {% if app.user %}
                <div class="relative group">
                    <button class="w-10 h-10 rounded-full bg-gray-300 overflow-hidden">
                        {% if app.user.avatarUrl %}
                            <img src="{{ app.user.avatarUrl }}" alt="Profile picture" class="w-full h-full object-cover rounded-full">
                        {% else %}
                            <span class="w-full h-full inline-flex items-center justify-center text-sm font-semibold text-gray-700">
                                {{ app.user.email|first|upper }}
                            </span>
                        {% endif %}
                    </button>
                    <div class="absolute right-0 mt-2 hidden rounded-md border border-black/10 bg-white p-2 shadow-lg group-hover:block group-focus-within:block">
                        <p class="px-2 py-1 text-xs text-gray-500">{{ app.user.email }}</p>
                        <a href="{{ path('app_settings') }}" class="block rounded px-2 py-2 text-sm text-gray-700 hover:bg-gray-100">My Profile</a>
                        <a href="{{ path('app_orders') }}" class="block rounded px-2 py-2 text-sm text-gray-700 hover:bg-gray-100">My Orders</a>
                        <a href="{{ path('app_saved_index') }}" class="block rounded px-2 py-2 text-sm text-gray-700 hover:bg-gray-100">Saved Items</a>
                        <a href="{{ path('app_cart_index') }}" class="block rounded px-2 py-2 text-sm text-gray-700 hover:bg-gray-100">Cart</a>
                        <a href="{{ path('app_logout') }}" class="block rounded px-2 py-2 text-sm text-red-600 hover:bg-red-50">Logout</a>
                    </div>
                </div>
            {% else %}
                <a href="{{ path('app_login') }}" class="text-sm font-medium text-gray-700 hover:text-orange-600">Login</a>
                <a href="{{ path('app_register') }}" class="rounded-md bg-orange-500 px-3 py-2 text-sm font-medium text-white hover:bg-orange-600">Register</a>
            {% endif %}
        </div>
    </div>
    <div class="w-full border-b border-black/10 flex items-center gap-6 h-12">
        <a href="#" class="text-sm font-medium text-gray-600 hover:text-gray-900">Home</a>
        <a href="{{ path('app_shop') }}" class="text-sm font-medium text-orange-600 hover:text-gray-900">Shop</a>
        <a href="#" class="text-sm font-medium text-gray-600 hover:text-gray-900">Collections</a>
        <a href="#" class="text-sm font-medium text-gray-600 hover:text-gray-900">New</a>
        <a href="#" class="text-sm font-medium text-gray-600 hover:text-gray-900">About Us</a>
    </div>
</nav>
