<div class="group flex flex-col w-full h-fit border rounded-md border-black/10 overflow-hidden shadow hover:shadow-md duration-300 transition-shadow bg-white">
    <a href="{{ path('app_product_show', {id: product.id}) }}" class="aspect-square select-none block relative">
        <img src="{{ product.image ?: 'https://picsum.photos/seed/product-' ~ product.id ~ '/800/800' }}" alt="{{ product.name }}" class="w-full h-full object-cover">
    </a>
    <div class="p-3 space-y-3">
        <div class="flex items-start justify-between gap-3">
            <a href="{{ path('app_product_show', {id: product.id}) }}" class="block">
                <p class="text-sm text-gray-800 line-clamp-2">{{ product.name }}</p>
                <p class="font-semibold text-gray-900">{{ product.price|number_format(2, '.', ',') }} DT</p>
            </a>
            {% set isSaved = product.id in (savedProductIds|default([])) %}
            <form method="post" action="{{ path('app_saved_toggle', {id: product.id}) }}" class="js-save-item">
                <input type="hidden" name="_token" value="{{ csrf_token('save_' ~ product.id) }}">
                <button type="submit" class="rounded-full p-1 text-gray-500 hover:text-orange-600 transition-colors" data-saved="{{ isSaved ? '1' : '0' }}">
                    {{ ux_icon(isSaved ? 'mdi:heart' : 'mdi:heart-outline', {class: "w-5 h-5"}) }}
                </button>
            </form>
        </div>
        <form action="{{ path('app_cart_add') }}" method="post" class="js-add-to-cart">
            <input type="hidden" name="productId" value="{{ product.id }}">
            <input type="hidden" name="quantity" value="1">
            <input type="hidden" name="_token" value="{{ csrf_token('cart_add_' ~ product.id) }}">
            <button
                type="submit"
                class="w-full rounded-md bg-orange-500 px-3 py-2 text-sm font-medium text-white transition hover:bg-orange-600 md:opacity-0 md:group-hover:opacity-100"
                data-default-label="Add to cart"
                data-added-label="Added!"
            >
                Add to cart
            </button>
        </form>
    </div>
</div>
