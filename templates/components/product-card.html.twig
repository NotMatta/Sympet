<div class="flex flex-col w-full h-[360px] border rounded-md border-black/10 overflow-hidden shadow hover:shadow-md duration-300 transition-shadow">
    <div class="aspect-square select-none">
        <img src="{{ product.image }}" alt="{{ product.name }}" class="w-full object-cover">
    </div>
    <div class="h-16 border-black/10 p-2">
        <p class="text-sm">{{ product.name }}</p>
        <p class="font-semibold">{{ product.price }} DT</p>
    </div>
</div>
