{% extends 'base.html.twig' %}

{% block title %}Your Cart | Sympet{% endblock %}

{% block body %}
<div class="min-h-screen noto-sans flex flex-col bg-gray-50">
    {% include 'includes/navbar.html.twig' with {
        search: search,
        selectedCategories: selectedCategories,
        sort: sort,
        cartItemCount: cartItemCount,
        savedItemsCount: savedItemsCount
    } %}

    <main class="w-full grow px-4 py-6">
        <div class="mx-auto w-full max-w-7xl space-y-4">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="rounded-md px-4 py-3 text-sm {% if type == 'success' %}bg-emerald-50 text-emerald-700{% elseif type == 'error' %}bg-red-50 text-red-700{% else %}bg-amber-50 text-amber-700{% endif %}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            <h1 class="text-2xl font-bold text-gray-900">Your cart</h1>

            {% if items is empty %}
                <div class="rounded-lg border border-dashed border-gray-300 bg-white p-8 text-center">
                    <p class="text-lg font-semibold text-gray-800">Your cart is empty</p>
                    <p class="mt-2 text-sm text-gray-500">Add products from the shop to start your order.</p>
                    <a href="{{ path('app_shop') }}" class="mt-4 inline-flex rounded-md bg-orange-500 px-4 py-2 text-sm font-medium text-white hover:bg-orange-600">
                        Continue shopping
                    </a>
                </div>
            {% else %}
                <div class="grid gap-6 lg:grid-cols-[1fr_320px]">
                    <section class="space-y-3">
                        {% for item in items %}
                            {% set product = item.product %}
                            <article class="rounded-lg border border-black/10 bg-white p-4 shadow-sm">
                                <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                                    <div class="flex items-center gap-4">
                                        <a href="{{ path('app_product_show', {id: product.id}) }}" class="h-20 w-20 shrink-0 overflow-hidden rounded-md bg-gray-100">
                                            <img src="{{ product.image ?: 'https://picsum.photos/seed/product-' ~ product.id ~ '/200/200' }}" alt="{{ product.name }}" class="h-full w-full object-cover">
                                        </a>
                                        <div>
                                            <a href="{{ path('app_product_show', {id: product.id}) }}" class="font-semibold text-gray-900 hover:text-orange-600">
                                                {{ product.name }}
                                            </a>
                                            <p class="text-sm text-gray-500">{{ product.price|number_format(2, '.', ',') }} DT each</p>
                                            <p class="text-sm font-medium text-gray-800">Line total: {{ item.lineTotal|number_format(2, '.', ',') }} DT</p>
                                        </div>
                                    </div>

                                    <div class="flex items-center gap-2">
                                        <form method="post" action="{{ path('app_cart_update', {id: product.id}) }}" class="flex items-center gap-2">
                                            <input type="hidden" name="_token" value="{{ csrf_token('cart_update_' ~ product.id) }}">
                                            <input
                                                type="number"
                                                min="1"
                                                max="{{ min(product.quantity, 99) }}"
                                                name="quantity"
                                                value="{{ item.quantity }}"
                                                class="w-20 rounded-md border border-gray-300 px-2 py-1 text-sm"
                                            >
                                            <button type="submit" class="rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                                Update
                                            </button>
                                        </form>

                                        <form method="post" action="{{ path('app_cart_remove', {id: product.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('cart_remove_' ~ product.id) }}">
                                            <button type="submit" class="rounded-md border border-red-300 px-3 py-2 text-sm text-red-600 hover:bg-red-50">
                                                Remove
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                    </section>

                    <aside class="h-fit rounded-lg border border-black/10 bg-white p-5 shadow-sm">
                        <h2 class="text-lg font-semibold text-gray-900">Order summary</h2>
                        <div class="mt-4 space-y-2 text-sm text-gray-700">
                            <div class="flex items-center justify-between">
                                <span>Items</span>
                                <span>{{ cartItemCount }}</span>
                            </div>
                            <div class="flex items-center justify-between">
                                <span>Subtotal</span>
                                <span>{{ subtotal|number_format(2, '.', ',') }} DT</span>
                            </div>
                            <div class="flex items-center justify-between border-t border-gray-200 pt-2 text-base font-semibold text-gray-900">
                                <span>Total</span>
                                <span>{{ subtotal|number_format(2, '.', ',') }} DT</span>
                            </div>
                        </div>

                        {% if app.user %}
                            <form method="post" action="{{ path('app_payment_checkout') }}" class="mt-5" data-turbo="false">
                                <input type="hidden" name="_token" value="{{ csrf_token('checkout') }}">
                                <button type="submit" class="w-full rounded-md bg-orange-500 px-4 py-3 text-sm font-semibold text-white hover:bg-orange-600">
                                    Proceed to checkout
                                </button>
                            </form>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="mt-5 block w-full rounded-md bg-orange-500 px-4 py-3 text-center text-sm font-semibold text-white hover:bg-orange-600">
                                Login to checkout
                            </a>
                        {% endif %}
                        <p class="mt-3 text-xs text-gray-500">Stripe test card: 4242 4242 4242 4242</p>
                    </aside>
                </div>
            {% endif %}
        </div>
    </main>
</div>
{% endblock %}
