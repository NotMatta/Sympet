{% extends 'base.html.twig' %}

{% block title %}Shop | Sympet{% endblock %}

{% block body %}
<div class="min-h-screen noto-sans flex flex-col bg-gray-50">
    {% include 'includes/navbar.html.twig' with {
        search: search,
        selectedCategories: selectedCategoryIds,
        sort: sort
    } %}

    <div class="w-full grow px-4 py-6">
        <div class="mx-auto flex w-full max-w-7xl flex-col gap-6 lg:flex-row">
            <aside class="w-full shrink-0 rounded-lg border border-black/10 bg-white p-4 shadow-sm lg:w-72 lg:self-start">
                <form action="{{ path('app_shop') }}" method="get" class="space-y-5">
                    {% if search %}
                        <input type="hidden" name="search" value="{{ search }}">
                    {% endif %}

                    <div class="space-y-2">
                        <h2 class="text-lg font-semibold">Categories</h2>
                        <div class="space-y-2">
                            {% for category in categories %}
                                <label for="category-{{ category.id }}" class="flex cursor-pointer items-center gap-2 text-sm text-gray-700">
                                    <input
                                        id="category-{{ category.id }}"
                                        type="checkbox"
                                        name="categories[]"
                                        value="{{ category.id }}"
                                        class="h-4 w-4 rounded border-gray-300 text-orange-500 focus:ring-orange-500"
                                        {% if category.id in selectedCategoryIds %}checked{% endif %}
                                    >
                                    <span>{{ category.name }}</span>
                                </label>
                            {% else %}
                                <p class="text-sm text-gray-500">No categories available.</p>
                            {% endfor %}
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label for="sort" class="text-sm font-medium text-gray-700">Sort by</label>
                        <select
                            id="sort"
                            name="sort"
                            class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none focus:ring-1 focus:ring-orange-500"
                        >
                            {% for value, label in sortOptions %}
                                <option value="{{ value }}" {% if value == sort %}selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="flex gap-2">
                        <button type="submit" class="inline-flex items-center justify-center rounded-md bg-orange-500 px-4 py-2 text-sm font-medium text-white transition hover:bg-orange-600">
                            Apply filters
                        </button>
                        <a href="{{ path('app_shop') }}" class="inline-flex items-center justify-center rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 transition hover:bg-gray-100">
                            Reset
                        </a>
                    </div>
                </form>
            </aside>

            <section class="flex min-w-0 grow flex-col gap-4">
                <div class="flex flex-col gap-3 rounded-lg border border-black/10 bg-white p-4 shadow-sm">
                    <p class="text-sm text-gray-600">
                        Showing {{ products|length }} of {{ totalFiltered }} product{% if totalFiltered != 1 %}s{% endif %}
                        {% if totalVisible != totalFiltered %}(from {{ totalVisible }} total){% endif %}
                    </p>
                    <div class="flex flex-wrap items-center gap-2">
                        {% if search %}
                            <span class="inline-flex items-center rounded-full bg-orange-50 px-3 py-1 text-xs font-medium text-orange-700">
                                Search: "{{ search }}"
                            </span>
                        {% endif %}
                        {% for category in categories %}
                            {% if category.id in selectedCategoryIds %}
                                <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-700">
                                    {{ category.name }}
                                </span>
                            {% endif %}
                        {% endfor %}
                        {% if not search and selectedCategoryIds is empty %}
                            <span class="text-xs text-gray-500">No filters applied.</span>
                        {% endif %}
                    </div>
                </div>

                {% if products is empty %}
                    <div class="flex min-h-72 flex-col items-center justify-center gap-2 rounded-lg border border-dashed border-gray-300 bg-white p-8 text-center">
                        <p class="text-lg font-semibold text-gray-800">No products found</p>
                        <p class="text-sm text-gray-500">Try changing your search, categories, or sorting.</p>
                        <a href="{{ path('app_shop') }}" class="mt-2 inline-flex items-center rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100">
                            Reset all filters
                        </a>
                    </div>
                {% else %}
                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
                        {% for product in products %}
                            {% include 'components/product-card.html.twig' with {'product': product} %}
                        {% endfor %}
                    </div>
                {% endif %}

                {% if totalPages > 1 %}
                    {% set baseQuery = {'search': search, 'sort': sort, 'categories': selectedCategoryIds} %}
                    <nav class="flex items-center justify-center gap-2 pt-2">
                        {% if page > 1 %}
                            <a
                                href="{{ path('app_shop', baseQuery|merge({'page': page - 1})) }}"
                                class="rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-700 hover:bg-gray-100"
                            >
                                Prev
                            </a>
                        {% endif %}

                        {% for p in 1..totalPages %}
                            <a
                                href="{{ path('app_shop', baseQuery|merge({'page': p})) }}"
                                class="rounded-md px-3 py-2 text-sm {% if p == page %}bg-orange-500 text-white{% else %}border border-gray-300 text-gray-700 hover:bg-gray-100{% endif %}"
                            >
                                {{ p }}
                            </a>
                        {% endfor %}

                        {% if page < totalPages %}
                            <a
                                href="{{ path('app_shop', baseQuery|merge({'page': page + 1})) }}"
                                class="rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-700 hover:bg-gray-100"
                            >
                                Next
                            </a>
                        {% endif %}
                    </nav>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
