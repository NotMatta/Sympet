{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} | Sympet{% endblock %}

{% block body %}
<div class="min-h-screen noto-sans flex flex-col bg-gray-50">
    {% include 'includes/navbar.html.twig' with {
        search: search,
        selectedCategories: selectedCategories,
        sort: sort,
        cartItemCount: cartItemCount,
        savedItemsCount: savedItemsCount
    } %}

    <main class="w-full grow px-4 py-6">
        <div class="mx-auto grid w-full max-w-7xl gap-6 lg:grid-cols-2">
            <section class="rounded-lg border border-black/10 bg-white p-4 shadow-sm">
                <div class="aspect-square overflow-hidden rounded-lg bg-gray-100">
                    <img src="{{ product.image ?: 'https://picsum.photos/seed/product-' ~ product.id ~ '/1000/1000' }}" alt="{{ product.name }}" class="h-full w-full object-cover">
                </div>
            </section>

            <section class="rounded-lg border border-black/10 bg-white p-6 shadow-sm">
                <div class="mb-4 flex items-center justify-between gap-2">
                    {% if product.category %}
                        <a href="{{ path('app_shop', {categories: [product.category.id]}) }}" class="inline-flex items-center rounded-full bg-orange-50 px-3 py-1 text-xs font-medium text-orange-700">
                            {{ product.category.name }}
                        </a>
                    {% endif %}
                    {% set isSaved = product.id in (savedProductIds|default([])) %}
                    <form method="post" action="{{ path('app_saved_toggle', {id: product.id}) }}" class="js-save-item">
                        <input type="hidden" name="_token" value="{{ csrf_token('save_' ~ product.id) }}">
                        <button type="submit" class="inline-flex items-center gap-2 rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-700 hover:bg-gray-100">
                            {{ ux_icon(isSaved ? 'mdi:heart' : 'mdi:heart-outline', {class: "w-5 h-5"}) }}
                            <span>{{ isSaved ? 'Saved' : 'Save' }}</span>
                        </button>
                    </form>
                </div>

                <h1 class="text-3xl font-bold text-gray-900">{{ product.name }}</h1>
                <p class="mt-3 text-2xl font-semibold text-orange-600">{{ product.price|number_format(2, '.', ',') }} DT</p>
                <p class="mt-5 whitespace-pre-line text-sm leading-6 text-gray-700">{{ product.description }}</p>

                <div class="mt-6">
                    {% if product.quantity > 0 %}
                        <p class="text-sm font-medium text-emerald-600">In stock ({{ product.quantity }} available)</p>
                    {% else %}
                        <p class="text-sm font-medium text-red-600">Out of stock</p>
                    {% endif %}
                </div>

                {% if product.quantity > 0 %}
                    {% set maxQuantity = min(product.quantity, 99) %}
                    <form action="{{ path('app_cart_add') }}" method="post" class="js-add-to-cart mt-6 space-y-4">
                        <input type="hidden" name="productId" value="{{ product.id }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('cart_add_' ~ product.id) }}">
                        <div class="space-y-2">
                            <label for="quantity" class="text-sm font-medium text-gray-700">Quantity</label>
                            <select id="quantity" name="quantity" class="w-28 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm focus:border-orange-500 focus:outline-none focus:ring-1 focus:ring-orange-500">
                                {% for quantity in 1..maxQuantity %}
                                    <option value="{{ quantity }}">{{ quantity }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <button
                            type="submit"
                            class="inline-flex w-full items-center justify-center rounded-md bg-orange-500 px-6 py-3 text-base font-semibold text-white transition hover:bg-orange-600"
                            data-default-label="Add to cart"
                            data-added-label="Added!"
                        >
                            Add to cart
                        </button>
                    </form>
                {% endif %}
            </section>
        </div>

        {% if relatedProducts is not empty %}
            <section class="mx-auto mt-8 w-full max-w-7xl">
                <h2 class="mb-4 text-xl font-semibold text-gray-900">Related products</h2>
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
                    {% for product in relatedProducts %}
                        {% include 'components/product-card.html.twig' with {'product': product} %}
                    {% endfor %}
                </div>
            </section>
        {% endif %}
    </main>
</div>
{% endblock %}
