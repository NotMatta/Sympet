{% extends 'base.html.twig' %}

{% block title %}Saved Items | Sympet{% endblock %}

{% block body %}
<div class="min-h-screen noto-sans flex flex-col bg-gray-50">
    {% include 'includes/navbar.html.twig' with {
        cartItemCount: cartItemCount,
        savedItemsCount: savedItemsCount,
        search: search,
        sort: sort,
        selectedCategories: selectedCategories
    } %}
    <main class="grow px-4 py-6">
        <div class="mx-auto max-w-7xl space-y-4">
            <h1 class="text-2xl font-bold text-gray-900">Saved Items</h1>
            {% if savedItems is empty %}
                <div class="rounded-lg border border-dashed border-gray-300 bg-white p-8 text-center text-gray-600">
                    No saved items yet.
                </div>
            {% else %}
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
                    {% for savedItem in savedItems %}
                        {% if savedItem.product %}
                            {% include 'components/product-card.html.twig' with {'product': savedItem.product, 'savedProductIds': savedProductIds} %}
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </main>
</div>
{% endblock %}
